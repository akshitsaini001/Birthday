    <style>
        body { 
            font-family: 'Impact', 'Arial Black', sans-serif; 
            background: linear-gradient(135deg, #3b82f6, #2563eb); /* Bright Superhero Blue */
            margin: 0; 
            padding: 0;
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            overflow: hidden;
            position: relative;
        }

        #bg-container {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: 1;
            pointer-events: none;
        }

        /* Exploding Comic Book Pop-Up Card */
        .welcome-card { 
            text-align: center; 
            background: #facc15; /* Electric Yellow */
            padding: 40px; 
            border-radius: 30px; 
            box-shadow: 0 20px 0 #ca8a04, 0 30px 40px rgba(0,0,0,0.3); 
            z-index: 10;
            max-width: 85%;
            width: 400px;
            border: 8px solid #ffffff;
            animation: cardPopIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        h1 { 
            color: #dc2626; /* Racing Red */
            font-size: 3.5em; 
            margin: 0 0 10px 0;
            text-shadow: 3px 3px 0px #ffffff;
            letter-spacing: 2px;
        }

        p { 
            color: #1e3a8a; 
            font-size: 1.5em;
            margin-bottom: 30px; 
            font-weight: bold;
            line-height: 1.4;
        }

        /* Huge Action Button */
        .btn { 
            background-color: #dc2626; 
            color: white; 
            border: none; 
            padding: 20px 45px; 
            font-size: 1.5em; 
            font-weight: bold;
            border-radius: 50px; 
            cursor: pointer; 
            text-decoration: none; 
            display: inline-block;
            box-shadow: 0 8px 0 #991b1b, 0 15px 20px rgba(0,0,0,0.2);
            transition: all 0.1s ease;
        }

        .btn:hover { 
            transform: translateY(2px);
            box-shadow: 0 6px 0 #991b1b, 0 10px 15px rgba(0,0,0,0.2);
        }

        .btn:active {
            transform: translateY(8px);
            box-shadow: 0 0px 0 #991b1b;
        }

        @keyframes cardPopIn {
            0% { opacity: 0; transform: scale(0) rotate(-20deg); }
            100% { opacity: 1; transform: scale(1) rotate(0deg); }
        }

        @keyframes floatUpAndSpin {
            0% { transform: translateY(105vh) scale(0.6) rotate(0deg); opacity: 0; }
            15% { opacity: 1; }
            100% { transform: translateY(-15vh) scale(1.3) rotate(360deg); opacity: 0; }
        }
    </style>
</head>
<body>

    <div id="bg-container"></div>

    <div class="welcome-card">
        <h1>HEY CHAMP! ⚡</h1>
        <p>Are you ready for a super secret birthday mission?</p>
        <!-- Replace 'celebrate' with your actual WordPress page slug or URL -->
        <a href="/celebrate" class="btn">START GAME! 🎮</a>
    </div>

    <script>
        const container = document.getElementById('bg-container');
        const elements = ['🎈', '🚗', '🚀', '⭐', '🎂', '🦖', '⚡'];

        function createItem(startAtBottom = true) {
            const item = document.createElement('div');
            item.style.position = 'absolute';
            item.style.bottom = startAtBottom ? '-10vh' : Math.random() * 100 + 'vh';
            item.innerText = elements[Math.floor(Math.random() * elements.length)];
            item.style.left = Math.random() * 100 + 'vw';
            item.style.fontSize = (Math.random() * 2 + 1.5) + 'rem';
            item.style.animation = 'floatUpAndSpin linear forwards';
            
            const duration = Math.random() * 3 + 4; // Fast, energetic movement (4s to 7s)
            item.style.animationDuration = duration + 's';
            
            container.appendChild(item);
            setTimeout(() => { item.remove(); }, duration * 1000);
        }

        // Instant burst of toys and balloons, then continuous streaming
        for (let i = 0; i < 20; i++) { createItem(false); }
        setInterval(() => { createItem(true); }, 250);
    </script>
</body>
</html>