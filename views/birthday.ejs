<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HAPPY 6th BIRTHDAY! 🎂</title>
  <style>
    /* Base Setup */
    body {
      font-family: 'Impact', 'Arial Black', sans-serif;
      background: linear-gradient(to bottom, #eff6ff, #dbeafe);
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    #celebration-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 1;
      pointer-events: none;
    }

    /* Main Container - Adjusted padding for cleaner spacing */
    .main-content {
      position: relative;
      z-index: 10;
      text-align: center;
      max-width: 1000px;
      /* Widened to fit 3 photos beautifully side-by-side */
      width: 100%;
      padding: 40px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      box-sizing: border-box;
    }

    .birthday-header {
      font-size: 3.5rem;
      color: #e11d48;
      /* Bright Punchy Crimson */
      margin: 0;
      text-shadow: 3px 3px 0px #ffffff, 5px 5px 0px #2563eb;
      animation: bounceTitle 1.5s infinite ease-in-out;
      letter-spacing: 1px;
    }

    /* Responsive Title Scale for Smaller Screens */
    @media (max-width: 480px) {
      .birthday-header {
        font-size: 2.3rem;
      }

      .subtitle {
        font-size: 1.1rem;
      }
    }

    .subtitle {
      font-size: 1.5rem;
      color: #2563eb;
      margin: 10px 0 35px 0;
      font-weight: bold;
      background: #facc15;
      padding: 5px 20px;
      border-radius: 10px;
      box-shadow: 4px 4px 0px #1e3a8a;
    }

    /* NEW: Responsive Photo Grid Section */
    .photo-grid {
      display: grid;
      grid-template-columns: 1fr;
      /* 1 column on mobile */
      gap: 30px;
      width: 100%;
      max-width: 900px;
      margin-bottom: 40px;
      padding: 10px;
      box-sizing: border-box;
      justify-items: center;
    }

    /* 3 Columns on Tablets and Desktop Screens */
    @media (min-width: 768px) {
      .photo-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Comic Book / Action Card Portrait Frame */
    .photo-card-container {
      width: 100%;
      max-width: 270px;
      /* Constrained for perfect grid sizing */
      background: #ffffff;
      padding: 15px 15px 20px 15px;
      border-radius: 20px;
      box-shadow: 0 12px 0px #bfdbfe, 0 20px 30px rgba(0, 0, 0, 0.12);
      border: 5px solid #2563eb;
      display: flex;
      flex-direction: column;
      align-items: center;
      box-sizing: border-box;
      transition: transform 0.3s ease;
    }

    /* Staggered comic rotation for the 3 frames */
    .card-1 {
      transform: rotate(-3deg);
      animation: photoSwayLeft 4.5s infinite ease-in-out;
    }

    .card-2 {
      transform: rotate(2deg);
      animation: photoSwayRight 5s infinite ease-in-out;
    }

    .card-3 {
      transform: rotate(-1deg);
      animation: photoSwayLeft 5.5s infinite ease-in-out;
    }

    .photo-card-container:hover {
      transform: scale(1.05) rotate(0deg) !important;
      z-index: 20;
    }

    .photo-wrapper {
      width: 100%;
      height: 300px;
      overflow: hidden;
      border-radius: 12px;
      background-color: #e2e8f0;
    }

    .photo-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .her-name-tag {
      font-size: 1.6rem;
      color: #dc2626;
      font-weight: bold;
      margin-top: 15px;
      text-shadow: 1px 1px 0px #fff;
      white-space: nowrap;
    }

    /* Video Panel Setup */
    .video-panel {
      width: 100%;
      max-width: 500px;
      aspect-ratio: 16 / 9;
      margin-bottom: 35px;
      background: white;
      padding: 10px;
      border-radius: 20px;
      border: 4px solid #facc15;
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
      box-sizing: border-box;
    }

    .video-panel iframe {
      width: 100%;
      height: 100%;
      border: none;
      border-radius: 12px;
    }

    /* Power Wishes Box */
    .wishes-card {
      background: #ffffff;
      padding: 35px;
      border-radius: 25px;
      border: 4px solid #2563eb;
      box-shadow: 0 15px 0px #bfdbfe;
      color: #1e3a8a;
      font-family: 'Arial', sans-serif;
      line-height: 1.6;
      font-size: 1.3rem;
      font-weight: bold;
      max-width: 600px;
      width: 100%;
      box-sizing: border-box;
    }

    .wishes-card p {
      margin: 0 0 15px 0;
    }

    .wishes-card p:last-child {
      margin-bottom: 0;
      font-size: 1.6rem;
      color: #dc2626;
    }

    /* --- Keyframe Animations --- */
    @keyframes bounceTitle {

      0%,
      100% {
        transform: translateY(0) scale(1);
      }

      50% {
        transform: translateY(-10px) scale(1.03);
      }
    }

    @keyframes photoSwayLeft {

      0%,
      100% {
        transform: rotate(-3deg);
      }

      50% {
        transform: rotate(1deg) translateY(-4px);
      }
    }

    @keyframes photoSwayRight {

      0%,
      100% {
        transform: rotate(3deg);
      }

      50% {
        transform: rotate(-1deg) translateY(-4px);
      }
    }

    @keyframes driftUp {
      0% {
        transform: translateY(105vh) scale(0.6);
        opacity: 0;
      }

      10% {
        opacity: 1;
      }

      100% {
        transform: translateY(-15vh) scale(1.2);
        opacity: 0;
      }
    }
  </style>
</head>

<body>

  <div id="celebration-bg"></div>

  <div class="main-content">
    <h1 class="birthday-header">HAPPY 6th BIRTHDAY! 🎉</h1>
    <div class="subtitle">⭐ OUR LITTLE SUPERHERO ⭐</div>

    <!-- NEW: 3 Photo Grid Container -->
    <div class="photo-grid">

      <!-- PHOTO FRAME 1 -->
      <div class="photo-card-container card-1">
        <div class="photo-wrapper">
          <!-- Replace with your first photo URL -->
          <img src="https://res.cloudinary.com/dkd2ekmmf/image/upload/v1781283626/v2_bj7iw9.jpg" alt="Birthday Boy 1">
        </div>
        <div class="her-name-tag">SUPER VIHAAN ⚡</div>
      </div>

      <!-- PHOTO FRAME 2 -->
      <div class="photo-card-container card-2">
        <div class="photo-wrapper">
          <!-- Replace with your second photo URL -->
          <img src="https://res.cloudinary.com/dkd2ekmmf/image/upload/v1781283627/v3_vmcihv.jpg" alt="Birthday Boy 2">
        </div>
        <div class="her-name-tag">CHAMPION ⭐</div>
      </div>

      <!-- PHOTO FRAME 3 -->
      <div class="photo-card-container card-3">
        <div class="photo-wrapper">
          <!-- Replace with your third photo URL -->
          <img src="https://res.cloudinary.com/dkd2ekmmf/image/upload/v1781283626/v1_hwiauh.jpg" alt="Birthday Boy 3">
        </div>
        <div class="her-name-tag">HERO VIHAAN 🚀</div>
      </div>

    </div>

    <!-- Video Player -->
    <div class="video-panel">
      <div id="player"></div>
    </div>

    <!-- Wishes Board -->
    <div class="wishes-card">
      <p>Happy Birthday Vihaan Saini.</p>
      <p>Have the most epic day ever! Your Big Brother loves you! 🎂🚗🎮⚡</p>
    </div>
  </div>

  <script src="https://www.youtube.com/iframe_api"></script>

  <script>
    let player;

    function onYouTubeIframeAPIReady() {
      player = new YT.Player('player', {
        height: '315',
        width: '560',
        videoId: 'zFVPuO7Gtqo',
        playerVars: {
          'autoplay': 1,
          'controls': 1,
          'rel': 0,
          'loop': 1,
          'start': 11, // Starts at your custom 11-second mark
          'playlist': 'zFVPuO7Gtqo'
        },
        events: {
          'onReady': onPlayerReady
        }
      });
    }

    function onPlayerReady(event) {
      // Tells the browser to unmute the track and start processing playback
      event.target.unmute();
      event.target.playVideo();
    }

    // Background Ambiance Falling / Drifting Loops
    const bgContainer = document.getElementById('celebration-bg');
    const elements = ['🎈', '⚡', '🚀', '⭐', '🎂', 'Rex', '🚗'];

    function spawnCelebrationItem() {
      const item = document.createElement('div');
      item.style.position = 'absolute';
      item.style.bottom = '-10vh';
      item.innerText = elements[Math.floor(Math.random() * elements.length)];
      item.style.left = Math.random() * 100 + 'vw';
      item.style.fontSize = (Math.random() * 1.5 + 1.2) + 'rem';
      item.style.animation = 'driftUp linear forwards';
      const duration = Math.random() * 3 + 4;
      item.style.animationDuration = duration + 's';
      bgContainer.appendChild(item);
      setTimeout(() => {
        item.remove();
      }, duration * 1000);
    }

    setInterval(spawnCelebrationItem, 250);
    for (let i = 0; i < 15; i++) {
      setTimeout(spawnCelebrationItem, Math.random() * 2000);
    }
  </script>
</body>

</html>