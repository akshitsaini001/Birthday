<body>

    <div id="bg-container"></div>

    <div class="mission-board" id="secret-board">
        <div id="text-content"></div>
        <!-- Replace 'birthday' with your actual final WordPress page slug -->
        <a href="/birthday" class="next-btn" id="action-button">! Click !</a>
    </div>

    <script>
        const bgContainer = document.getElementById('bg-container');
        const board = document.getElementById('secret-board');
        const textElement = document.getElementById('text-content');
        const actionBtn = document.getElementById('action-button');

        const elementsPool = ['⚡', '🚀', '🦖', '⭐', '🎈', '🎮', '💥'];
        
        function spawnParticle() {
            const el = document.createElement('div');
            el.style.position = 'absolute';
            el.style.bottom = '-5vh';
            el.innerText = elementsPool[Math.floor(Math.random() * elementsPool.length)];
            el.style.left = Math.random() * 100 + 'vw';
            el.style.fontSize = (Math.random() * 1.8 + 1.5) + 'rem';
            el.style.animation = 'particleFly linear forwards';
            
            const duration = Math.random() * 2 + 3;
            el.style.animationDuration = duration + 's';
            
            bgContainer.appendChild(el);
            setTimeout(() => { el.remove(); }, duration * 1000);
        }

        // Intense burst for first 5 seconds
        const particleInterval = setInterval(spawnParticle, 100);

        // Word-by-word briefing text
        const messageString = "ATTENTION CHIEF OFFICER!... Mission Objective: Celebrate your 6th Birthday!... Status: You have successfully leveled up to age 6!... Reward unlocked: Time to open your final gift file... Click below to claim your prize!...";
        const wordsArray = messageString.split(' ');
        let wordIdx = 0;

        function typeWords() {
            if (wordIdx < wordsArray.length) {
                textElement.innerHTML += wordsArray[wordIdx] + ' ';
                wordIdx++;
                setTimeout(typeWords, 250); // Punchy typing pace
            } else {
                actionBtn.classList.add('reveal');
            }
        }

        // Trigger Board Entry after exactly 5 seconds
        setTimeout(() => {
            clearInterval(particleInterval);
            setInterval(spawnParticle, 350); // Calm background stream
            board.classList.add('show');
            setTimeout(typeWords, 800);
        }, 5000);
    </script>
</body>
</html>